# OpenAI — powers streaming AI steps, tool-calling chat, structured outputs, and embeddings.
OPENAI_API_KEY=sk-your-openai-key

# Supabase — hosts the tasks table + pgvector for semantic search.
# Get these from your project's "Project Settings → API" page.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional — only needed if you swap the provider to Anthropic.
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
